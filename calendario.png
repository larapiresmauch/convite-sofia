:root {
  --blue: #5d90bd;
  --blue-dark: #4f7fa8;
  --blue-deep: #3d6f9b;
  --paper: #f4f0ea;
  --ink: #274960;
  --silver: #d8d8d4;
}

* {
  box-sizing: border-box;
}

html,
body {
  width: 100%;
  min-height: 100%;
  margin: 0;
}

body {
  overflow: hidden;
  color: var(--ink);
  background: var(--blue);
  font-family: "Montserrat", Arial, sans-serif;
}

button,
a {
  -webkit-tap-highlight-color: transparent;
}

.stage {
  position: relative;
  width: 100vw;
  height: 100svh;
  min-height: 620px;
  overflow: hidden;
  background:
    radial-gradient(circle at 50% 38%, rgba(255, 255, 255, 0.14), transparent 24rem),
    var(--blue);
}

.envelope-screen,
.invite-screen {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
}

.envelope-screen {
  z-index: 4;
  background: var(--blue);
  transition: opacity 700ms ease, visibility 700ms ease;
}

.envelope {
  position: absolute;
  inset: 0;
  display: flex;
}

.envelope-half {
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, #6a9ac3, var(--blue));
  transition: transform 1050ms cubic-bezier(0.76, 0, 0.24, 1);
  will-change: transform;
}

.envelope-half-right {
  background: linear-gradient(90deg, var(--blue-dark), #6a9ac3);
}

.envelope-fold {
  position: absolute;
  top: 0;
  left: 50%;
  width: min(9vw, 72px);
  height: 100%;
  transform: translateX(-50%);
  background: linear-gradient(90deg, rgba(40, 76, 103, 0.42), rgba(255, 255, 255, 0.08), transparent);
  pointer-events: none;
}

.seal-button {
  position: relative;
  z-index: 6;
  width: clamp(118px, 27vw, 178px);
  aspect-ratio: 1;
  padding: 0;
  border: 0;
  border-radius: 999px;
  background: transparent;
  cursor: pointer;
  filter: drop-shadow(0 14px 18px rgba(18, 39, 54, 0.28));
  animation: sealFloat 2.6s ease-in-out infinite;
}

.seal-button img,
.invite-monogram {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.seal-button:focus-visible,
.round-action:focus-visible {
  outline: 3px solid rgba(255, 255, 255, 0.88);
  outline-offset: 6px;
}

.tap-hint {
  position: absolute;
  z-index: 5;
  left: 50%;
  bottom: max(28px, env(safe-area-inset-bottom));
  width: min(86vw, 360px);
  margin: 0;
  transform: translateX(-50%);
  color: rgba(255, 255, 255, 0.82);
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-align: center;
  text-transform: uppercase;
}

.invite-screen {
  z-index: 2;
  padding: max(34px, env(safe-area-inset-top)) 18px max(24px, env(safe-area-inset-bottom));
  overflow-y: auto;
  opacity: 0;
  visibility: hidden;
  background:
    linear-gradient(rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.07)),
    url("../img/fundo.png") center / cover no-repeat,
    #f5f2ec;
  transition: opacity 700ms ease 280ms, visibility 700ms ease 280ms;
}

.invite-card {
  display: grid;
  align-content: center;
  width: min(100%, 760px);
  min-height: 100%;
  margin: auto;
  padding: clamp(72px, 13vh, 142px) 0 clamp(120px, 14vh, 180px);
  border: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
  text-align: center;
  transform: translateY(22px) scale(0.98);
  transition: transform 700ms ease 360ms;
}

h1 {
  margin: 0;
  color: var(--blue);
  font-family: "Allura", "Segoe Script", "Brush Script MT", "Cormorant Garamond", Georgia, serif;
  font-size: clamp(6.4rem, 30vw, 12.5rem);
  font-weight: 400;
  line-height: 0.72;
}

.age {
  margin: 0 0 clamp(74px, 12vh, 112px);
  color: var(--blue);
  font-size: clamp(2.25rem, 10vw, 4rem);
  font-weight: 300;
  line-height: 1;
}

.date-block {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  align-items: center;
  width: min(82vw, 460px);
  margin: 0 auto clamp(28px, 4.4vh, 48px);
  color: var(--blue);
}

.date-block strong {
  display: grid;
  place-items: center;
  min-width: clamp(104px, 25vw, 142px);
  min-height: clamp(70px, 16vw, 98px);
  border-inline: clamp(10px, 3vw, 14px) solid rgba(76, 116, 151, 0.24);
  font-size: clamp(4rem, 15vw, 6rem);
  font-weight: 700;
  line-height: 1;
}

.date-side {
  display: grid;
  gap: 8px;
  font-size: clamp(1.75rem, 7vw, 3rem);
  font-weight: 300;
  line-height: 1.05;
}

.venue {
  width: min(92vw, 780px);
  margin: 0 auto clamp(38px, 6.6vh, 68px);
  color: var(--blue);
}

.venue h2,
.venue p {
  margin: 0;
  font-weight: 300;
  line-height: 1.25;
}

.venue h2 {
  font-size: clamp(1.85rem, 6.4vw, 3.1rem);
}

.venue p {
  margin-top: 8px;
  font-size: clamp(1.38rem, 5.1vw, 2.55rem);
}

.invite-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: clamp(26px, 9vw, 64px);
  width: min(80vw, 440px);
  margin: 0 auto;
}

.round-action {
  display: grid;
  justify-items: center;
  align-content: start;
  width: clamp(116px, 34vw, 160px);
  color: var(--blue);
  font-size: clamp(1.05rem, 4.2vw, 1.35rem);
  font-weight: 700;
  line-height: 1.18;
  text-decoration: none;
}

.action-icon {
  display: grid;
  place-items: center;
  width: clamp(86px, 24vw, 118px);
  aspect-ratio: 1;
  margin-bottom: 10px;
  border-radius: 999px;
  background: rgba(194, 210, 225, 0.95);
}

.action-icon img {
  display: block;
  width: 58%;
  height: 58%;
  object-fit: contain;
  filter: brightness(0);
}

.round-action strong {
  display: block;
}

.stage.opened .envelope-half-left {
  transform: translateX(-101%);
}

.stage.opened .envelope-half-right {
  transform: translateX(101%);
}

.stage.opened .seal-button {
  animation: none;
  transform: scale(0.72);
  opacity: 0;
  transition: transform 520ms ease, opacity 420ms ease;
}

.stage.opened .tap-hint {
  opacity: 0;
  transition: opacity 250ms ease;
}

.stage.opened .envelope-screen {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.stage.opened .invite-screen,
.invite-screen.is-visible {
  opacity: 1;
  visibility: visible;
}

.stage.opened .invite-card,
.direct-invite .invite-card {
  transform: translateY(0) scale(1);
}

.direct-invite body,
.direct-invite {
  overflow: auto;
}

@keyframes sealFloat {
  0%,
  100% {
    transform: translateY(0) scale(1);
  }

  50% {
    transform: translateY(-7px) scale(1.02);
  }
}

@media (max-width: 430px) {
  .stage {
    min-height: 100svh;
  }

  .invite-screen {
    align-items: start;
    padding-inline: 14px;
  }

  .invite-card {
    width: 100%;
  }
}

@media (max-height: 740px) {
  .invite-card {
    padding-top: 50px;
    padding-bottom: 82px;
  }

  .age {
    margin-bottom: 46px;
  }

  .venue {
    margin-bottom: 30px;
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 0.01ms !important;
  }
}
